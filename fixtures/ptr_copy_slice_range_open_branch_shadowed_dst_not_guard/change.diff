diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,21 @@
+pub fn copy_checked(src: &[u8], dst: &mut [u8], count: usize) {
+    if src.len() >= count {
+        if dst.len() >= count {
+            let mut other = [0_u8; 1];
+            let dst = &mut other[..];
+            // SAFETY: fixture checks that shadowed open-branch destination guards are not ptr::copy range evidence.
+            unsafe { core::ptr::copy(src.as_ptr(), dst.as_mut_ptr(), count) }
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::copy_checked;
+
+    #[test]
+    fn mentions_copy_checked() {
+        let _ = stringify!(copy_checked);
+    }
+}
