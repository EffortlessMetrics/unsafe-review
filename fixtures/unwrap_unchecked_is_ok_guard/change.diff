diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,17 @@
+pub fn extract(result: Result<u8, ()>) -> u8 {
+    if result.is_ok() {
+        // SAFETY: the branch above checked that this result is Ok.
+        unsafe { result.unwrap_unchecked() }
+    } else {
+        0
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::extract;
+
+    #[test]
+    fn extracts_ok_value() {
+        assert_eq!(extract(Ok(7)), 7);
+    }
+}
