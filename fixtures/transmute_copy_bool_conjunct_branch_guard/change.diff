+pub fn copy_byte_to_bool_conjunct(value: u8, allow_conversion: bool) -> bool {
+    assert_eq!(core::mem::size_of::<u8>(), core::mem::size_of::<bool>());
+    if value <= 1 && allow_conversion {
+        // SAFETY: size equality is asserted and this open branch constrains the referenced byte domain.
+        unsafe { core::mem::transmute_copy::<u8, bool>(&value) }
+    } else {
+        false
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::copy_byte_to_bool_conjunct;
+
+    #[test]
+    fn copies_known_bool_byte() {
+        let _value = copy_byte_to_bool_conjunct(1, true);
+    }
+}

