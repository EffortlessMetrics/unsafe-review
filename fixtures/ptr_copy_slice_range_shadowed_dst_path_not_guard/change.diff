diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,37 @@
+pub struct Buffers<'a> {
+    pub src: &'a [u8],
+    pub dst: &'a mut [u8],
+}
+
+pub fn copy_checked<'a>(
+    buffers: Buffers<'a>,
+    count: usize,
+    fallback: &'a mut [u8],
+) -> &'a mut [u8] {
+    assert!(buffers.src.len() >= count);
+    assert!(buffers.dst.len() >= count);
+    let buffers = Buffers {
+        src: buffers.src,
+        dst: fallback,
+    };
+    // SAFETY: fixture checks that a shadowed destination path length guard is not range evidence.
+    unsafe { core::ptr::copy(buffers.src.as_ptr(), buffers.dst.as_mut_ptr(), count) }
+    buffers.dst
+}
+
+#[cfg(test)]
+mod tests {
+    use super::{Buffers, copy_checked};
+
+    #[test]
+    fn copies_bytes() {
+        let src = [1_u8, 2, 3, 4];
+        let mut original_dst = [9_u8, 9, 9, 9];
+        let mut fallback = [0_u8; 4];
+        let buffers = Buffers {
+            src: &src,
+            dst: &mut original_dst,
+        };
+        let dst = copy_checked(buffers, fallback.len(), &mut fallback);
+        assert_eq!(dst, src.as_slice());
+    }
+}
