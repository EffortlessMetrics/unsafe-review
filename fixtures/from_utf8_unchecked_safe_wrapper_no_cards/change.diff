diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,21 @@
+/// A safe codec type with a safe `from_utf8_unchecked` method that validates encoding.
+/// Calling this method outside any unsafe scope must not produce a ReviewCard.
+pub struct Codec {
+    buffer: Vec<u8>,
+}
+
+impl Codec {
+    pub fn new(buffer: Vec<u8>) -> Self {
+        Codec { buffer }
+    }
+
+    /// Safe `from_utf8_unchecked` that validates UTF-8 encoding first — no unsafe involved.
+    pub fn from_utf8_unchecked(&self) -> Option<&str> {
+        std::str::from_utf8(&self.buffer).ok()
+    }
+}
+
+/// Safe caller that invokes the safe `Codec::from_utf8_unchecked` — must not produce a card.
+pub fn decode(codec: &Codec) -> Option<&str> {
+    codec.from_utf8_unchecked()
+}
