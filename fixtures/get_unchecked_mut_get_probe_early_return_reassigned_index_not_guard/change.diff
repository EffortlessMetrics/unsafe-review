+pub fn pick_after_stale_get_probe_return(
+    values: &mut [u8],
+    mut index: usize,
+) -> Option<&mut u8> {
+    if values.get(index).is_none() {
+        return None;
+    }
+    index = values.len();
+    // SAFETY: this fixture intentionally changes the checked index before use.
+    Some(unsafe { values.get_unchecked_mut(index) })
+}
