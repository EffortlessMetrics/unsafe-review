diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,21 @@
+pub fn keep_prefix(values: &mut Vec<u8>, start: usize, end: usize) {
+    let len = values.len();
+    assert!(start <= end);
+    assert!(end <= len);
+    // SAFETY: `start` is no greater than the current initialized length, so
+    // this only shrinks the initialized range.
+    unsafe {
+        values.set_len(start);
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::keep_prefix;
+
+    #[test]
+    fn keep_prefix_shrinks_to_start() {
+        let mut values = vec![1, 2, 3];
+        keep_prefix(&mut values, 1, 2);
+        assert_eq!(values, vec![1]);
+    }
+}

