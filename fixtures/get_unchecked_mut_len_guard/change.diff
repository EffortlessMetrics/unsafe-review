diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,8 @@
+pub fn pick_checked(values: &mut [u8], index: usize) -> Option<&mut u8> {
+    if index < values.len() {
+        // SAFETY: `index` was checked against `values.len()`.
+        Some(unsafe { values.get_unchecked_mut(index) })
+    } else {
+        None
+    }
+}
