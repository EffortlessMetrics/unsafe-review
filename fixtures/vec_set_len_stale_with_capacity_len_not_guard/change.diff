+pub fn grow_after_len_change(mut new_len: usize) -> Vec<u8> {
+    let mut values = Vec::with_capacity(new_len);
+    new_len = values.capacity() + 1;
+    // SAFETY: this fixture checks that stale with_capacity length evidence does not apply after reassignment.
+    unsafe { values.set_len(new_len) };
+    values
