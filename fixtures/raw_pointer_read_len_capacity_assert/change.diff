diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,24 @@
+pub struct ArrayVec<T, const CAP: usize> {
+    len: usize,
+    storage: [T; CAP],
+}
+
+impl<T, const CAP: usize> ArrayVec<T, CAP> {
+    pub fn len(&self) -> usize {
+        self.len
+    }
+
+    pub fn capacity(&self) -> usize {
+        CAP
+    }
+
+    pub fn as_ptr(&self) -> *const T {
+        self.storage.as_ptr()
+    }
+}
+
+pub fn read_full_array<T: Copy, const CAP: usize>(values: &ArrayVec<T, CAP>) -> [T; CAP] {
+    debug_assert_eq!(values.len(), values.capacity());
+    let ptr = values.as_ptr();
+    // SAFETY: this fixture documents the length/capacity precondition but
+    // intentionally omits the other raw-read proof obligations.
+    unsafe { core::ptr::read(ptr as *const [T; CAP]) }
+}
