diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -0,0 +1,36 @@
+pub struct Buffers<'a> {
+    pub src: &'a [u8],
+    pub dst: &'a mut [u8],
+}
+
+pub fn copy_checked<'a>(buffers: Buffers<'a>, count: usize, fallback: &'a [u8]) {
+    if count > buffers.src.len() || count > buffers.dst.len() {
+        return;
+    }
+    let buffers = Buffers {
+        src: fallback,
+        dst: buffers.dst,
+    };
+    // SAFETY: fixture checks that stale disjunctive early-return source path
+    // guards are not range evidence after the receiver path is shadowed.
+    unsafe {
+        core::ptr::copy_nonoverlapping(buffers.src.as_ptr(), buffers.dst.as_mut_ptr(), count)
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::{copy_checked, Buffers};
+
+    #[test]
+    fn copies_from_shadowed_source_path() {
+        let src = [1_u8, 2, 3, 4];
+        let fallback = [5_u8, 6, 7, 8];
+        let mut dst = [0_u8; 4];
+        let buffers = Buffers {
+            src: &src,
+            dst: &mut dst,
+        };
+        copy_checked(buffers, fallback.len(), &fallback);
+        assert_eq!(dst, fallback);
+    }
+}
