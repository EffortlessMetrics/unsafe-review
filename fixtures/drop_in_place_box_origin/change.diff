+pub fn drop_owned_box(value: Box<String>) {
+    let ptr = Box::into_raw(value);
+    // SAFETY: this fixture ties the pointer to Box::into_raw and drops it once.
+    unsafe {
+        core::ptr::drop_in_place(ptr);
+    }
+}
