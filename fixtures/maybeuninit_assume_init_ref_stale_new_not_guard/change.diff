+use core::mem::MaybeUninit;
+
+pub fn borrow_after_stale_new() {
+    let mut slot = MaybeUninit::new(7_u32);
+    slot = MaybeUninit::uninit();
+    // SAFETY: fixture checks that stale MaybeUninit::new evidence does not
+    // initialize the current slot before assume_init_ref.
+    let _value = unsafe { slot.assume_init_ref() };
+}
+
+#[cfg(test)]
+mod tests {
+    use super::borrow_after_stale_new;
+
+    #[test]
+    fn mentions_borrow_after_stale_new() {
+        let _ = core::mem::size_of_val(&(borrow_after_stale_new as fn()));
+    }
+}
