diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,34 @@
+pub struct Control {
+    ctrl: *const u8,
+    bytes: usize,
+}
+
+impl Control {
+    pub fn new(ctrl: *const u8, bytes: usize) -> Self {
+        Self { ctrl, bytes }
+    }
+
+    fn num_ctrl_bytes(&self) -> usize {
+        self.bytes
+    }
+
+    pub fn ctrl(&self, index: usize) -> Option<*const u8> {
+        if index >= self.num_ctrl_bytes() {
+            return None;
+        }
+        // SAFETY: fixture exposes an invalid-path early return bounds guard.
+        let ptr = unsafe { self.ctrl.add(index) };
+        Some(ptr)
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::Control;
+
+    #[test]
+    fn ctrl_uses_return_guard() {
+        let bytes = [0_u8; 4];
+        let control = Control::new(bytes.as_ptr(), bytes.len());
+        let _ = control.ctrl(0);
+    }
+}
