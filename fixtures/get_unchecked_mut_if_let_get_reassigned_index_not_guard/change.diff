+pub fn pick_after_stale_if_let_get(values: &mut [u8], mut index: usize) -> Option<&mut u8> {
+    if let Some(_) = values.get(index) {
+        index = values.len();
+        // SAFETY: this fixture intentionally changes the checked index before use.
+        Some(unsafe { values.get_unchecked_mut(index) })
+    } else {
+        None
+    }
+}
