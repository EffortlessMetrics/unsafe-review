+use core::mem::MaybeUninit;
+
+pub fn borrow_after_prefixed_slot() {
+    let mutslot = MaybeUninit::new(7_u32);
+    let slot = MaybeUninit::<u32>::uninit();
+    let _ = mutslot;
+    // SAFETY: fixture intentionally initializes `mutslot`, not `slot`, before
+    // assume_init_ref.
+    let _value = unsafe { slot.assume_init_ref() };
+}
+
+#[cfg(test)]
+mod tests {
+    use super::borrow_after_prefixed_slot;
+
+    #[test]
+    fn mentions_borrow_after_prefixed_slot() {
+        let _ = core::mem::size_of_val(&(borrow_after_prefixed_slot as fn()));
+    }
+}
