+use core::mem::MaybeUninit;
+
+pub fn read_after_prefixed_slot() -> u32 {
+    let mutslot = MaybeUninit::new(7_u32);
+    let slot = MaybeUninit::<u32>::uninit();
+    let _ = mutslot;
+    // SAFETY: fixture intentionally initializes `mutslot`, not `slot`, before
+    // assume_init_read.
+    unsafe { slot.assume_init_read() }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::read_after_prefixed_slot;
+
+    #[test]
+    fn mentions_read_after_prefixed_slot() {
+        let _ = core::mem::size_of_val(&(read_after_prefixed_slot as fn() -> u32));
+    }
+}
