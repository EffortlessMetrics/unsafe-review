diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,5 @@
+pub fn round_trip_box(value: Box<u8>) -> Box<u8> {
+    let ptr = Box::into_raw(value);
+    // SAFETY: this fixture ties the raw pointer to Box::into_raw in the same scope.
+    unsafe { Box::from_raw(ptr) }
+}
