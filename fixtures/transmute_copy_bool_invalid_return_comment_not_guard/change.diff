diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,18 @@
+pub fn copy_byte_to_bool_with_commented_return(value: u8) -> bool {
+    debug_assert_eq!(core::mem::size_of::<u8>(), core::mem::size_of::<bool>());
+    if value > 1 {
+        // return false for invalid bool byte patterns before transmute_copy.
+        observe_invalid_byte(value);
+    }
+    // SAFETY: this fixture intentionally leaves the invalid byte branch without an executable return guard.
+    unsafe { core::mem::transmute_copy::<u8, bool>(&value) }
+}
+
+fn observe_invalid_byte(_value: u8) {}
+
+#[cfg(test)]
+mod tests {
+    use super::copy_byte_to_bool_with_commented_return;
+
+    #[test]
+    fn copies_known_bool_byte() {
+        let _value = copy_byte_to_bool_with_commented_return(1);
+    }
+}
