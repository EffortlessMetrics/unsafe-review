+pub fn copy_byte_to_bool_observed(value: u8) -> bool {
+    debug_assert_eq!(core::mem::size_of::<u8>(), core::mem::size_of::<bool>());
+    let _valid_bool_byte = value <= 1;
+    // SAFETY: fixture deliberately observes the bool byte-domain predicate without checking it.
+    unsafe { core::mem::transmute_copy::<u8, bool>(&value) }
+}
