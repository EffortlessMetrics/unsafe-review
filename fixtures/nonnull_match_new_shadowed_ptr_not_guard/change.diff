diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,26 @@
+use core::ptr::NonNull;
+
+pub fn expose_nonnull_after_shadowed_match(
+    ptr: *mut u8,
+    other: *mut u8,
+) -> Option<NonNull<u8>> {
+    match NonNull::new(ptr) {
+        Some(_) => {
+            let ptr = other;
+            // SAFETY: this fixture intentionally shadows the checked pointer before use.
+            Some(unsafe { NonNull::new_unchecked(ptr) })
+        }
+        None => None,
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::expose_nonnull_after_shadowed_match;
+
+    #[test]
+    fn mentions_expose_nonnull_after_shadowed_match() {
+        let _ = stringify!(expose_nonnull_after_shadowed_match);
+    }
+}
