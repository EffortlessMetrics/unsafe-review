+pub fn read_status(register: *const u32) -> Option<u32> {
+    // SAFETY: this fixture intentionally checks alignment after the volatile read.
+    let status = unsafe { register.read_volatile() };
+    if !register.is_aligned() {
+        return None;
+    }
+    Some(status)
+}
