diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,18 @@
+pub fn copy_byte_to_bool_or_false(value: u8) -> bool {
+    debug_assert_eq!(core::mem::size_of::<u8>(), core::mem::size_of::<bool>());
+    if value > 1 {
+        return false;
+    }
+    // SAFETY: size equality is checked, and invalid bool byte patterns return before transmute_copy.
+    unsafe { core::mem::transmute_copy::<u8, bool>(&value) }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::copy_byte_to_bool_or_false;
+
+    #[test]
+    fn copies_known_bool_byte() {
+        let _value = copy_byte_to_bool_or_false(1);
+    }
+}

