+use core::mem::MaybeUninit;
+
+pub fn drop_after_new(value: String) {
+    let mut slot = MaybeUninit::new(value);
+    // SAFETY: this fixture exposes a same-slot MaybeUninit::new before
+    // assume_init_drop.
+    unsafe { slot.assume_init_drop() }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::drop_after_new;
+
+    #[test]
+    fn drops_after_new() {
+        drop_after_new(String::from("initialized"));
+    }
+}
