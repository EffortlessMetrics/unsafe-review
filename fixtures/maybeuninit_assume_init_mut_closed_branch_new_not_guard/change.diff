+use core::mem::MaybeUninit;
+
+pub fn mutate_after_closed_new_branch(init: bool) -> u32 {
+    let mut slot = MaybeUninit::<u32>::uninit();
+    if init {
+        let slot = MaybeUninit::new(7_u32);
+        let _ = slot.as_ptr();
+    }
+    // SAFETY: fixture checks that closed-branch MaybeUninit::new evidence
+    // does not initialize the outer slot.
+    let value = unsafe { slot.assume_init_mut() };
+    *value += 1;
+    *value
+}
+
+#[cfg(test)]
+mod tests {
+    use super::mutate_after_closed_new_branch;
+
+    #[test]
+    fn mentions_mutate_after_closed_new_branch() {
+        let _ = core::mem::size_of_val(&(mutate_after_closed_new_branch as fn(bool) -> u32));
+    }
+}
