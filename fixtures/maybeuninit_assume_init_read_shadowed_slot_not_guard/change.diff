+use core::mem::MaybeUninit;
+
+pub fn read_shadowed() -> u32 {
+    let mut slot = MaybeUninit::<u32>::uninit();
+    slot.write(7);
+    let slot = MaybeUninit::<u32>::uninit();
+    // SAFETY: this fixture checks that shadowed writes do not initialize the current slot.
+    unsafe { slot.assume_init_read() }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::read_shadowed;
+
+    #[test]
+    fn reads_shadowed() {
+        let _ = core::mem::size_of_val(&(read_shadowed as fn() -> u32));
+    }
+}
