+pub fn reset_then_keep_prefix(mut values: Vec<u8>, start: usize, end: usize) -> Vec<u8> {
+    let len = values.len();
+    values = Vec::new();
+    assert!(start <= end);
+    assert!(end <= len);
+    // SAFETY: fixture checks that a stale length binding is not shrink evidence.
+    unsafe {
+        values.set_len(start);
+    }
+    values
+}
