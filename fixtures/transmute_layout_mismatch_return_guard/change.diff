diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,16 @@
+pub fn byte_to_bool_layout_mismatch_return(value: u8) -> bool {
+    if core::mem::size_of::<u8>() != core::mem::size_of::<bool>() {
+        return false;
+    }
+    // SAFETY: the mismatch branch exits before this call, but this fixture intentionally lacks a valid-value proof that value is 0 or 1.
+    unsafe { core::mem::transmute::<u8, bool>(value) }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::byte_to_bool_layout_mismatch_return;
+
+    #[test]
+    fn converts_known_bool_byte() {
+        let _value = byte_to_bool_layout_mismatch_return(1);
+    }
+}

