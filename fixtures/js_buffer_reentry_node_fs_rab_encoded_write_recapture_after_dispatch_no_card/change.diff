diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,61 @@
+pub struct JSValue;
+pub struct GlobalObject;
+pub struct StringOrBuffer;
+#[derive(Clone, Copy)]
+pub struct Encoding;
+
+pub fn from_js_with_encoding_maybe_async_into<T>(
+    _global: &mut GlobalObject,
+    _value: JSValue,
+    _encoding: Encoding,
+) -> Result<T, ()>
+where
+    T: Default,
+{
+    Ok(T::default())
+}
+
+impl Default for StringOrBuffer {
+    fn default() -> Self {
+        Self
+    }
+}
+
+impl StringOrBuffer {
+    pub fn slice(&self) -> &[u8] {
+        &[]
+    }
+}
+
+pub struct WriteFileArgs {
+    data: StringOrBuffer,
+}
+
+pub fn node_fs_rab_encoded_write_file(
+    global: &mut GlobalObject,
+    stale_data: JSValue,
+    refreshed_data: JSValue,
+    encoding: Encoding,
+) -> Result<usize, ()> {
+    let stale_args = WriteFileArgs {
+        data: from_js_with_encoding_maybe_async_into::<StringOrBuffer>(
+            global, stale_data, encoding,
+        )?,
+    };
+    dispatch_async_worker(&stale_args)?;
+    let refreshed_args = WriteFileArgs {
+        data: from_js_with_encoding_maybe_async_into::<StringOrBuffer>(
+            global,
+            refreshed_data,
+            encoding,
+        )?,
+    };
+    write_file_worker(&refreshed_args)
+}
+
+fn dispatch_async_worker(_args: &WriteFileArgs) -> Result<(), ()> {
+    Ok(())
+}
+
+fn write_file_worker(args: &WriteFileArgs) -> Result<usize, ()> {
+    let bytes = args.data.slice();
+    Ok(bytes.len())
+}
