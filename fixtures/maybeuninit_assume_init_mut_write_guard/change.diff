+use core::mem::MaybeUninit;
+
+pub fn mutate_written() -> u32 {
+    let mut slot = MaybeUninit::<u32>::uninit();
+    slot.write(7);
+    // SAFETY: this fixture exposes a same-slot write before assume_init_mut.
+    let value = unsafe { slot.assume_init_mut() };
+    *value += 1;
+    *value
+}
+
+#[cfg(test)]
+mod tests {
+    use super::mutate_written;
+
+    #[test]
+    fn mutates_written() {
+        let _value = mutate_written();
+    }
+}
