diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,18 @@
+pub fn copy_byte_to_bool_conjunct_return(value: u8, disabled: bool) -> bool {
+    assert_eq!(core::mem::size_of::<u8>(), core::mem::size_of::<bool>());
+    if value > 1 && disabled {
+        return false;
+    }
+    // SAFETY: this fixture intentionally uses a conjunctive invalid-byte return guard.
+    unsafe { core::mem::transmute_copy::<u8, bool>(&value) }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::copy_byte_to_bool_conjunct_return;
+
+    #[test]
+    fn mentions_conjunctive_return() {
+        let _ = core::mem::size_of_val(&(copy_byte_to_bool_conjunct_return as fn(u8, bool) -> bool));
+    }
+}

