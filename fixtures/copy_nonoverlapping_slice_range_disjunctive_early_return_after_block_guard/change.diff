diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,23 @@
+pub fn copy_checked(src: &[u8], dst: &mut [u8], count: usize, note: bool) {
+    if count > src.len() || count > dst.len() {
+        if note {
+            let _observed = count;
+        }
+        return;
+    }
+    // SAFETY: fixture exposes a disjunctive invalid-range early return after a nested block.
+    unsafe { core::ptr::copy_nonoverlapping(src.as_ptr(), dst.as_mut_ptr(), count) }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::copy_checked;
+
+    #[test]
+    fn copies_bytes() {
+        let src = [1_u8, 2, 3, 4];
+        let mut dst = [0_u8; 4];
+        copy_checked(&src, &mut dst, src.len(), true);
+        assert_eq!(dst, src);
+    }
+}
