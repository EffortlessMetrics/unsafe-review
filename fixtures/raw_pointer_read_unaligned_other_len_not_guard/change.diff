--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,18 @@
+pub struct Header(u32);
+
+pub fn read_header(ptr: *const Header, other: &[u8]) -> Header {
+    assert!(other.len() >= core::mem::size_of::<Header>());
+    // SAFETY: fixture checks that an unrelated slice length guard is not bounds
+    // evidence for a read_unaligned from a different pointer.
+    unsafe { core::ptr::read_unaligned(ptr) }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::read_header;
+
+    #[test]
+    fn mentions_read_header() {
+        let _ = stringify!(read_header);
+    }
+}
