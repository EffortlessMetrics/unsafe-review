diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,0 +1,24 @@
+pub struct Header(u32);
+
+pub fn write_unaligned_header(bytes: &mut [u8], header: Header) {
+    assert!(bytes.len() >= core::mem::size_of::<Header>());
+    let ptr = bytes.as_mut_ptr().cast::<Header>();
+    if ptr.is_null() {
+        return;
+    }
+    // SAFETY: length and nullability are checked above; write_unaligned
+    // intentionally does not require alignment.
+    unsafe { ptr.write_unaligned(header) }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::{write_unaligned_header, Header};
+
+    #[test]
+    fn mentions_write_unaligned_header() {
+        let _ = stringify!(write_unaligned_header);
+        let _ = Header(0);
+    }
+}
